{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Gig worker registration data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "city": { "type": "string" },
        "deliveryType": { "type": "string", "enum": ["Bike", "Car", "Scooter"] },
        "hourlyIncome": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "city", "deliveryType", "hourlyIncome"]
    },
    "Policy": {
      "title": "Insurance Policy",
      "description": "Active weekly insurance policy",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired"] },
        "premium": { "type": "number" },
        "riskScore": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "premium", "riskScore", "startDate", "endDate"]
    },
    "Claim": {
      "title": "Automatic Claim",
      "description": "Claim generated by trigger engine",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "policyId": { "type": "string" },
        "triggerType": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["processed", "pending"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "policyId", "triggerType", "amount", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/policies/{policyId}": {
      "schema": "Policy",
      "description": "Insurance policies"
    },
    "/claims/{claimId}": {
      "schema": "Claim",
      "description": "Automatic claims history"
    }
  }
}
